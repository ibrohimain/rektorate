rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email in [
           'alisherusmankulov@gmail.com',
           'yorqinjon@gmail.com',
           'jamshid@gmail.com',
           'sanobar@gmail.com',
           'ochilovmahsud@gmail.com'
         ]);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['userId', 'adminId', 'dateTime', 'purpose', 'status']) &&
             data.userId is string &&
             data.adminId is string &&
             data.dateTime is string &&
             data.purpose is string &&
             data.status in ['pending', 'approved', 'rejected', 'completed'];
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.adminId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidAppointment(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.adminId || isAdmin()) && isValidAppointment(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
