{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phone1": { "type": "string" },
        "phone2": { "type": "string" },
        "workplace": { "type": "string" },
        "address": { "type": "string" },
        "position": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "adminRole": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment Request",
      "description": "Stores appointment requests made by users to admins.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "adminRole": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "purpose": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "adminId", "dateTime", "purpose", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment request documents."
    }
  }
}
